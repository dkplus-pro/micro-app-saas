{
  "name": "schema-uniapp-saas-factory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "node scripts/lint.mjs",
    "typecheck": "tsc --noEmit",
    "validate:schema": "node scripts/validate-schema.ts",
    "generate:tenant": "node scripts/generate-tenant.ts",
    "build:mp": "node scripts/build-tenant.ts",
    "build:tenant": "node scripts/build-tenant.ts",
    "build:all": "node scripts/batch-build.ts --tenants=app1,app2",
    "upload:tenant": "node scripts/upload-tenant.ts",
    "release:tenant": "node scripts/release-tenant.ts",
    "test": "node --test tests/*.test.mjs",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build:all"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.10.0"
}
