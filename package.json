{
  "name": "micro-app-saas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "validate:schema": "tsx scripts/validate-schema.ts",
    "generate:tenant": "tsx scripts/generate-tenant.ts",
    "build:tenant": "tsx scripts/build-tenant.ts",
    "batch:build": "tsx scripts/batch-build.ts",
    "upload:tenant": "tsx scripts/upload-tenant.ts",
    "release:tenant": "tsx scripts/release-tenant.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "node scripts/lint.mjs",
    "verify": "pnpm typecheck && pnpm test && pnpm lint && pnpm build:tenant -- --tenant=app1 && pnpm build:tenant -- --tenant=app2"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
