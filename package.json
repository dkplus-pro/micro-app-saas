{
  "name": "schema-uniapp-saas-factory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "node scripts/typecheck.mjs",
    "build:tools": "tsc -p tsconfig.json",
    "validate:schema": "npm run build:tools && node dist/scripts/validate-schema.js",
    "generate:tenant": "npm run build:tools && node dist/scripts/generate-tenant.js",
    "build:tenant": "npm run build:tools && node dist/scripts/build-tenant.js",
    "build:app1": "npm run build:tenant -- --tenant=app1",
    "build:app2": "npm run build:tenant -- --tenant=app2",
    "batch:build": "npm run build:tools && node dist/scripts/batch-build.js",
    "upload:tenant": "npm run build:tools && node dist/scripts/upload-tenant.js -- --dry-run",
    "release:tenant": "npm run build:tools && node dist/scripts/release-tenant.js -- --dry-run",
    "test": "node --test tests/*.test.mjs",
    "lint": "node scripts/check-no-tracked-node-modules.mjs && node scripts/check-no-tracked-artifacts.mjs && node scripts/lint.mjs",
    "runner:build": "node scripts/build-tenant.ts",
    "runner:batch": "node scripts/batch-build.ts",
    "runner:upload": "node scripts/upload-tenant.ts",
    "runner:release": "node scripts/release-tenant.ts",
    "guard:no-tracked-node-modules": "node scripts/check-no-tracked-node-modules.mjs",
    "guard:no-tracked-artifacts": "node scripts/check-no-tracked-artifacts.mjs",
    "guard:no-tracked-generated": "node scripts/check-no-tracked-artifacts.mjs",
    "dev:tenant": "node scripts/vite-tenant.ts dev",
    "dev:app1": "npm run dev:tenant -- --tenant=app1",
    "dev:app2": "npm run dev:tenant -- --tenant=app2",
    "vite:build:tenant": "node scripts/vite-tenant.ts --command=build",
    "vite:build:app1": "npm run vite:build:tenant -- --tenant=app1",
    "vite:build:app2": "npm run vite:build:tenant -- --tenant=app2",
    "guard:no-tracked-artifacts": "node scripts/check-no-tracked-artifacts.mjs",
    "build:tenant:vite": "node scripts/vite-tenant.ts --command=build",
    "build:vite:app1": "npm run build:tenant:vite -- --tenant=app1",
    "build:vite:app2": "npm run build:tenant:vite -- --tenant=app2",
    "guard:no-tracked-generated": "node scripts/check-no-tracked-artifacts.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@vitejs/plugin-vue": "^6.0.0",
    "typescript": "^5.5.4",
    "vite": "^7.0.0",
    "vue": "^3.5.0"
  }
}
