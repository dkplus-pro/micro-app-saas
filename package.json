{
  "name": "schema-uniapp-saas-factory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "node scripts/typecheck.mjs",
    "build:tools": "tsc -p tsconfig.json",
    "validate:schema": "npm run build:tools && node dist/scripts/validate-schema.js",
    "generate:tenant": "npm run build:tools && node dist/scripts/generate-tenant.js",
    "build:tenant": "npm run build:tools && node dist/scripts/build-tenant.js",
    "build:app1": "npm run build:tenant -- --tenant=app1",
    "build:app2": "npm run build:tenant -- --tenant=app2",
    "batch:build": "npm run build:tools && node dist/scripts/batch-build.js",
    "upload:tenant": "npm run build:tools && node dist/scripts/upload-tenant.js -- --dry-run",
    "release:tenant": "npm run build:tools && node dist/scripts/release-tenant.js -- --dry-run",
    "test": "node --test tests/*.test.mjs",
    "lint": "node scripts/check-no-tracked-node-modules.mjs && node scripts/check-no-tracked-artifacts.mjs && node scripts/lint.mjs",
    "runner:build": "node scripts/build-tenant.ts",
    "runner:batch": "node scripts/batch-build.ts",
    "runner:upload": "node scripts/upload-tenant.ts",
    "runner:release": "node scripts/release-tenant.ts",
    "guard:no-tracked-node-modules": "node scripts/check-no-tracked-node-modules.mjs",
    "guard:no-tracked-artifacts": "node scripts/check-no-tracked-artifacts.mjs",
    "guard:no-tracked-generated": "node scripts/check-no-tracked-artifacts.mjs",
    "dev:tenant": "node scripts/uniapp-tenant.ts --command=dev --platform=mp-weixin",
    "dev:app1": "npm run dev:app1:mp-weixin",
    "dev:app2": "npm run dev:app2:mp-weixin",
    "build:vite": "npm run build:mp-weixin --",
    "build:vite:tenant": "npm run build:mp-weixin --",
    "build:vite:app1": "npm run build:app1:mp-weixin",
    "build:vite:app2": "npm run build:app2:mp-weixin",
    "build:tenant:vite": "npm run build:mp-weixin --",
    "vite:build:tenant": "npm run build:mp-weixin --",
    "vite:build:app1": "npm run build:app1:mp-weixin",
    "vite:build:app2": "npm run build:app2:mp-weixin",
    "dev:mp-weixin": "node scripts/uniapp-tenant.ts --command=dev --platform=mp-weixin",
    "build:mp-weixin": "node scripts/uniapp-tenant.ts --command=build --platform=mp-weixin",
    "dev:app1:mp-weixin": "npm run dev:mp-weixin -- --tenant=app1",
    "dev:app2:mp-weixin": "npm run dev:mp-weixin -- --tenant=app2",
    "build:app1:mp-weixin": "npm run build:mp-weixin -- --tenant=app1",
    "build:app2:mp-weixin": "npm run build:mp-weixin -- --tenant=app2"
  },
  "devDependencies": {
    "@dcloudio/types": "3.4.31",
    "@dcloudio/uni-app": "3.0.0-5010420260703001",
    "@dcloudio/uni-mp-weixin": "3.0.0-5010420260703001",
    "@dcloudio/vite-plugin-uni": "3.0.0-5010420260703001",
    "@types/node": "^20.14.10",
    "typescript": "^5.5.4",
    "vite": "5.2.8",
    "vue": "3.5.38"
  }
}
