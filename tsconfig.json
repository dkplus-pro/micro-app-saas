{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["node"],
    "rootDir": "."
  },
  "include": ["packages/**/*.ts", "scripts/**/*.ts", "apps/miniapp-template/**/*.ts"],
  "exclude": ["node_modules", "apps/miniapp-template/dist"]
}
