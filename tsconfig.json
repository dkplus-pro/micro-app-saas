{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "dist",
    "declaration": true,
    "sourceMap": false,
    "types": [
      "node"
    ],
    "rewriteRelativeImportExtensions": true
  },
  "include": [
    "packages/**/*.ts",
    "schemas/**/*.ts",
    "scripts/**/*.ts",
    "apps/miniapp-template/src/**/*.ts",
    "apps/miniapp-template/vite.config.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
